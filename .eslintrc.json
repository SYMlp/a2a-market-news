{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "ignorePatterns": [".next/**", "node_modules/**", "coverage/**"],
  "rules": {
    "no-console": "error"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["scripts/**/*.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
