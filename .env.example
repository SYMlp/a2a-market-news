# SecondMe OAuth2
SECONDME_CLIENT_ID=your_client_id
SECONDME_CLIENT_SECRET=your_client_secret
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback

# SecondMe API
SECONDME_API_BASE_URL=https://app.mindos.com/gate/lab
SECONDME_OAUTH_URL=https://go.second.me/oauth/
SECONDME_TOKEN_ENDPOINT=https://app.mindos.com/gate/lab/api/oauth/token/code

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://user:password@host:5432/a2a_market_news

# Agent API Key (for /api/agent/* routes)
AGENT_API_KEY=change-me-to-a-secure-random-key
